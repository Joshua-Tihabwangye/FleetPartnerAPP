# EVzone Accounts OIDC
VITE_OIDC_AUTHORITY=https://accounts.evzone.app
VITE_OIDC_CLIENT_ID=evzone-charging-fleet-web
VITE_OIDC_REDIRECT_URI=https://fleet.evzonecharging.com/auth/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=https://fleet.evzonecharging.com/
VITE_OIDC_SCOPE=openid profile email phone evzone.principal evzone.trust evzone.organizations evzone.tenants charging.fleet charging.fleet.vehicles.manage charging.fleet.drivers.manage charging.fleet.sessions.read charging.fleet.policies.manage

# Fleet Backend API
VITE_BACKEND_BASE_URL=/api/v1
VITE_API_BASE_URL=/api/v1
VITE_SOCKET_BASE_URL=
VITE_SOCKET_PATH=/socket.io
VITE_APP_ID=fleet
